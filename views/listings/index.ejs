<% layout("/layouts/boilerplate") %>

<style>
    #filters {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 1rem;
    }

    .filter {
        color: #222;
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }

    .filter p {
        font-size: 0.8rem;
        margin-top: 5px;
    }

    .tax-info {
        display: none;
    }

    .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 3rem;
        display: flex;
        align-items: center;
    }

    .wishlist-btn{
position:absolute;
top:12px;
width:40px;
height:40px;
border:none;
border-radius:50%;
background:white;
font-size:22px;
cursor:pointer;
box-shadow:0 2px 8px rgba(0,0,0,.2);
transition:.3s;
z-index:1000;
}

.wishlist-btn.saved{
color:red;
}

.wishlist-btn:hover{
transform:scale(1.15);
}
</style>

<body>

<div id="filters">

    <a href="/listings?category=Trending" class="filter listing-link">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
    </a>

    <a href="/listings?category=Rooms" class="filter listing-link">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
    </a>

    <a href="/listings?category=Iconic City" class="filter listing-link">
        <div><i class="fa-solid fa-city"></i></div>
        <p>Iconic City</p>
    </a>

    <a href="/listings?category=Mountains" class="filter listing-link">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
    </a>

    <a href="/listings?category=Castles" class="filter listing-link">
        <div><i class="fa-brands fa-fort-awesome"></i></div>
        <p>Castles</p>
    </a>

    <a href="/listings?category=Amazing Pools" class="filter listing-link">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
    </a>

    <a href="/listings?category=Camping" class="filter listing-link">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
    </a>

    <a href="/listings?category=Farms" class="filter listing-link">
        <div><i class="fa-solid fa-cow"></i></div>
        <p>Farms</p>
    </a>

    <a href="/listings?category=Arctic" class="filter listing-link">
        <div><i class="fa-regular fa-snowflake"></i></div>
        <p>Arctic</p>
    </a>

    <a href="/listings?category=Domes" class="filter listing-link">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
    </a>

    <a href="/listings?category=Boats" class="filter listing-link">
        <div><i class="fa-solid fa-ship"></i></div>
        <p>Boats</p>
    </a>

    <div class="tax-toggle">
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault">
            <label class="form-check-label">
                Display total after taxes
            </label>
        </div>
    </div>

</div>

<% if(search){ %>
<h4 class="mt-3">
    Search Results for
    <span style="color:#fe424d">"<%= search %>"</span>
</h4>
<% } %>

<% if(allListings.length===0){ %>
<div class="alert alert-warning mt-3">
    No listings found.
</div>
<% } %>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

<% for(let listing of allListings){ %>

<div class="card col listing-card">

    <% if(currUser){ %>

    <button
    class="wishlist-btn <%= wishlistIds.includes(listing._id.toString()) ? 'saved' : '' %>"
    data-id="<%= listing._id %>">

        <%= wishlistIds.includes(listing._id.toString()) ? "❤️" : "🤍" %>

    </button>

    <% } %>

    <a href="/listings/<%= listing._id %>" class="listing-link">

        <img src="<%= listing.image.url %>"
        class="card-img-top"
        alt="listing_image"
        style="height:20rem">

        <div class="card-img-overlay">

</div>

        <div class="card-body">

            <p class="card-text">

                <b><%= listing.title %></b><br>

                &#8377; <%= listing.price.toLocaleString("en-IN") %> / night

                <i class="tax-info">&nbsp;&nbsp;+18% GST</i>

            </p>

        </div>

    </a>

</div>

<% } %>

</div>

</body>

<script>
let taxSwitch = document.getElementById("flexSwitchCheckDefault");

taxSwitch.addEventListener("click", () => {

let taxInfo = document.getElementsByClassName("tax-info");

for(let info of taxInfo){

if(info.style.display != "inline"){
info.style.display = "inline";
}else{
info.style.display = "none";
}

}

});
</script>

<script src="/js/wishlist.js"></script>